<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skalivo — AI Automation for Mortgage Brokers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --accent: #C8FF00;
  --bg: #0D0D0D;
  --bg2: #111111;
  --bg3: #161616;
  --white: #F4F4F0;
  --muted: #999999;
  --border: #1E1E1E;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  cursor: none;
}

/* CUSTOM CURSOR */
.cursor {
  position: fixed;
  width: 12px;
  height: 12px;
  background: var(--accent);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform 0.1s, width 0.3s, height 0.3s, opacity 0.3s;
  mix-blend-mode: difference;
}
.cursor-ring {
  position: fixed;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(200,255,0,0.4);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: transform 0.15s ease-out, width 0.3s, height 0.3s;
}
.cursor.hover { width: 20px; height: 20px; }
.cursor-ring.hover { width: 60px; height: 60px; border-color: var(--accent); }

/* NOISE OVERLAY */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.025;
  pointer-events: none;
  z-index: 9997;
}

/* NAV */
nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 48px;
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s, background 0.3s, backdrop-filter 0.3s;
}
nav.scrolled {
  border-color: var(--border);
  background: rgba(13,13,13,0.85);
  backdrop-filter: blur(16px);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-logo-icon {
  width: 32px;
  height: 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4px;
  padding: 6px;
  background: #000;
  border-radius: 6px;
}
.nav-logo-icon span {
  display: block;
  height: 2px;
  border-radius: 1px;
  background: var(--accent);
  transform-origin: left;
}
.nav-logo-icon span:nth-child(1) { width: 100%; opacity: 1; }
.nav-logo-icon span:nth-child(2) { width: 75%; opacity: 0.7; }
.nav-logo-icon span:nth-child(3) { width: 50%; opacity: 0.4; }
.nav-wordmark {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 3px;
  color: var(--white);
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 40px;
  list-style: none;
}
.nav-links a {
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--white);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--accent); }
.nav-cta {
  font-size: 12px !important;
  letter-spacing: 2px;
  text-transform: uppercase;
  background: var(--accent) !important;
  color: #000 !important;
  padding: 10px 20px;
  font-weight: 500 !important;
  text-decoration: none;
  transition: opacity 0.2s !important;
}
.nav-cta:hover { opacity: 0.85; }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 48px 80px;
  position: relative;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(200,255,0,0.06) 0%, transparent 70%);
}
.hero-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(200,255,0,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,255,0,0.04) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
}
.hero-tag {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 3px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 32px;
  opacity: 0;
  animation: fadeUp 0.8s 0.2s forwards; opacity: 1;
}
.hero-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(72px, 11vw, 180px);
  line-height: 0.92;
  letter-spacing: -1px;
  color: var(--white);
  margin-bottom: 40px;
  opacity: 0;
  animation: fadeUp 0.8s 0.4s forwards; opacity: 1;
}
.hero-headline em {
  font-style: normal;
  color: var(--accent);
  display: block;
}
.hero-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 40px;
  opacity: 0;
  animation: fadeUp 0.8s 0.6s forwards; opacity: 1;
}
.hero-sub {
  font-size: 16px;
  line-height: 1.7;
  color: var(--muted);
  max-width: 400px;
}
.hero-sub strong { color: var(--white); font-weight: 400; }
.hero-actions {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-shrink: 0;
}
.btn-primary {
  background: var(--accent);
  color: #000;
  padding: 16px 32px;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  font-weight: 500;
  display: inline-block;
  transition: opacity 0.2s;
}
.btn-primary:hover { opacity: 0.85; }
.btn-ghost {
  border: 1px solid var(--border);
  color: var(--muted);
  padding: 16px 32px;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  display: inline-block;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--white); color: var(--white); }

.hero-scroll {
  position: absolute;
  bottom: 40px;
  right: 48px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  opacity: 0;
  animation: fadeIn 1s 1.2s forwards; opacity: 1;
}
.hero-scroll span {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--muted);
  text-transform: uppercase;
  writing-mode: vertical-rl;
}
.scroll-line {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, var(--accent), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

/* MARQUEE */
.marquee-wrap {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 20px 0;
  overflow: hidden;
  background: var(--bg2);
}
.marquee-track {
  display: flex;
  gap: 0;
  animation: marquee 20s linear infinite;
  width: max-content;
}
.marquee-item {
  display: flex;
  align-items: center;
  gap: 40px;
  padding: 0 40px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 4px;
  color: var(--muted);
  white-space: nowrap;
}
.marquee-dot {
  width: 6px;
  height: 6px;
  background: var(--accent);
  border-radius: 50%;
  flex-shrink: 0;
}

/* SECTIONS */
section { padding: 120px 48px; }

.section-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 4px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 60px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
  max-width: 80px;
}

/* PAIN SECTION */
.pain {
  background: var(--bg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.pain-left h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  line-height: 0.95;
  color: var(--white);
  margin-bottom: 32px;
}
.pain-left h2 em { font-style: normal; color: var(--accent); }
.pain-left p {
  font-size: 16px;
  line-height: 1.8;
  color: var(--muted);
  margin-bottom: 40px;
}
.pain-stat {
  display: flex;
  gap: 40px;
  margin-top: 48px;
}
.stat-item {}
.stat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px;
  color: var(--accent);
  line-height: 1;
}
.stat-label {
  font-size: 12px;
  letter-spacing: 1px;
  color: var(--muted);
  margin-top: 4px;
}
.pain-right {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-top: 60px;
}
.pain-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border: 1px solid var(--border);
  background: var(--bg2);
  transition: border-color 0.3s, background 0.3s;
  cursor: default;
}
.pain-row:hover { border-color: var(--accent); background: rgba(200,255,0,0.03); }
.pain-row-left {
  display: flex;
  align-items: center;
  gap: 16px;
}
.pain-num {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--accent);
  opacity: 0.6;
}
.pain-title { font-size: 14px; color: var(--white); }
.pain-time {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted);
}

/* SOLUTIONS */
.solutions { background: var(--bg2); }
.solutions h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  line-height: 0.95;
  color: var(--white);
  margin-bottom: 80px;
}
.solutions h2 em { font-style: normal; color: var(--accent); }
.solutions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.sol-card {
  background: var(--bg);
  padding: 40px 32px;
  position: relative;
  overflow: hidden;
  transition: background 0.3s;
}
.sol-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s ease;
}
.sol-card:hover::before { transform: scaleX(1); }
.sol-card:hover { background: var(--bg3); }
.sol-number {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 80px;
  color: var(--border);
  line-height: 1;
  margin-bottom: 24px;
  transition: color 0.3s;
}
.sol-card:hover .sol-number { color: rgba(200,255,0,0.15); }
.sol-title {
  font-size: 18px;
  font-weight: 500;
  color: var(--white);
  margin-bottom: 12px;
}
.sol-desc {
  font-size: 14px;
  line-height: 1.7;
  color: var(--muted);
  margin-bottom: 24px;
}
.sol-save {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--accent);
  text-transform: uppercase;
}

/* HOW */
.how { background: var(--bg); }
.how-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.how h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  line-height: 0.95;
  color: var(--white);
  margin-bottom: 24px;
}
.how h2 em { font-style: normal; color: var(--accent); }
.how p {
  font-size: 15px;
  line-height: 1.8;
  color: var(--muted);
  margin-bottom: 40px;
}
.how-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.how-step {
  display: flex;
  gap: 24px;
  padding: 28px 0;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.how-step:last-child { border-bottom: none; }
.step-num {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--accent);
  padding-top: 3px;
  flex-shrink: 0;
}
.step-content {}
.step-title { font-size: 15px; color: var(--white); margin-bottom: 6px; font-weight: 400; }
.step-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }
.how-timeline {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 40px;
  margin-top: 60px;
}
.timeline-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 32px;
}
.timeline-row {
  display: flex;
  gap: 20px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}
.timeline-row:last-child { border-bottom: none; }
.t-day {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--accent);
  flex-shrink: 0;
  width: 48px;
  padding-top: 2px;
}
.t-text { font-size: 13px; color: var(--muted); line-height: 1.5; }
.t-text strong { color: var(--white); font-weight: 400; }

/* PRICING */
.pricing { background: var(--bg2); }
.pricing h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  line-height: 0.95;
  color: var(--white);
  margin-bottom: 80px;
}
.pricing h2 em { font-style: normal; color: var(--accent); }
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.price-card {
  background: var(--bg);
  padding: 48px 36px;
  position: relative;
  display: flex;
  flex-direction: column;
}
.price-card.featured {
  background: var(--bg3);
  border: 1px solid var(--accent);
}
.price-tag {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 32px;
  display: flex;
  justify-content: space-between;
}
.featured-badge {
  background: var(--accent);
  color: #000;
  font-family: 'Space Mono', monospace;
  font-size: 8px;
  letter-spacing: 2px;
  padding: 3px 8px;
  text-transform: uppercase;
}
.price-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px;
  color: var(--white);
  letter-spacing: 2px;
  margin-bottom: 8px;
}
.price-amount {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 64px;
  color: var(--white);
  line-height: 1;
  margin-bottom: 4px;
}
.price-amount span { font-size: 28px; vertical-align: top; margin-top: 12px; display: inline-block; }
.price-period { font-size: 12px; color: var(--muted); margin-bottom: 40px; }
.price-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
  margin-bottom: 40px;
}
.price-features li {
  display: flex;
  gap: 12px;
  font-size: 13px;
  color: var(--muted);
  line-height: 1.5;
}
.price-features li::before {
  content: '→';
  color: var(--accent);
  flex-shrink: 0;
}
.price-cta {
  display: block;
  text-align: center;
  padding: 14px;
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.2s;
  font-weight: 500;
}
.price-card:not(.featured) .price-cta {
  border: 1px solid var(--border);
  color: var(--muted);
}
.price-card:not(.featured) .price-cta:hover { border-color: var(--white); color: var(--white); }
.price-card.featured .price-cta {
  background: var(--accent);
  color: #000;
}
.price-card.featured .price-cta:hover { opacity: 0.85; }

/* CTA BAND */
.cta-band {
  background: var(--accent);
  padding: 100px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  position: relative;
  overflow: hidden;
}
.cta-band::before {
  content: 'SKALIVO';
  position: absolute;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 300px;
  color: rgba(0,0,0,0.06);
  right: -20px;
  top: 50%;
  transform: translateY(-50%);
  letter-spacing: -5px;
  pointer-events: none;
  white-space: nowrap;
}
.cta-band h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  color: #000;
  line-height: 0.95;
}
.cta-band p {
  font-size: 16px;
  color: rgba(0,0,0,0.6);
  margin-top: 16px;
  max-width: 360px;
}
.btn-dark {
  background: #000;
  color: var(--accent);
  padding: 20px 40px;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  font-weight: 500;
  flex-shrink: 0;
  transition: opacity 0.2s;
}
.btn-dark:hover { opacity: 0.85; }

/* CONTACT */
.contact {
  background: var(--bg);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contact h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 5vw, 80px);
  line-height: 0.95;
  color: var(--white);
  margin-bottom: 32px;
}
.contact h2 em { font-style: normal; color: var(--accent); }
.contact p {
  font-size: 15px;
  line-height: 1.8;
  color: var(--muted);
  margin-bottom: 40px;
}
.contact-details {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.contact-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.contact-key {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 3px;
  color: var(--accent);
  text-transform: uppercase;
}
.contact-val {
  font-size: 15px;
  color: var(--white);
  text-decoration: none;
  transition: color 0.2s;
}
.contact-val:hover { color: var(--accent); }
.contact-right {
  padding-top: 60px;
}
.contact-cta-block {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 48px;
}
.contact-cta-block h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px;
  color: var(--white);
  margin-bottom: 16px;
}
.contact-cta-block p {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 32px;
}
.contact-cta-block .btn-primary { width: 100%; text-align: center; }

/* FOOTER */
footer {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  padding: 40px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.footer-left {
  display: flex;
  align-items: center;
  gap: 16px;
}
.footer-wordmark {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 3px;
  color: var(--white);
}
.footer-abn {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
}
.footer-right {
  font-size: 12px;
  color: var(--muted);
  text-align: right;
}

/* REVEAL ANIMATIONS */
.reveal {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

@keyframes fadeUp {
  from { transform: translateY(20px); }
  to { transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.1); }
}

@media (max-width: 900px) {
  nav { padding: 16px 24px; }
  .nav-links { display: none; }
  section { padding: 80px 24px; }
  .hero { padding: 0 24px 60px; }
